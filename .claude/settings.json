{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "shell": "powershell",
            "command": "$lintOut = npm run lint 2>&1; if ($LASTEXITCODE -ne 0) { console.error(`${lintOut}`); exit 2 }; $testOut = npm test 2>&1; if ($LASTEXITCODE -ne 0) { $testOut; exit 2 }; Write-Output '{\"systemMessage\": \"✓ npm run lint and npm test passed\"}'",
            "timeout": 300,
            "statusMessage": "Running lint and tests before commit..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(npx wrangler deployments list *)",
      "Read",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git push)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}