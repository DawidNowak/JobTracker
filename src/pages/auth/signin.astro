---
import AuthLayout from "@/layouts/AuthLayout.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
---

<AuthLayout title="Zaloguj się" heading="Zaloguj się">
  <SignInForm serverError={error} client:load />
  <p class="mt-4 text-center text-sm text-neutral-600">
    Nie masz konta? <a href="/auth/signup" class="text-neutral-900 hover:underline">Zarejestruj się</a>
  </p>
</AuthLayout>
