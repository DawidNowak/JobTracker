---
import AuthLayout from "@/layouts/AuthLayout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<AuthLayout title="Zarejestruj się" heading="Zarejestruj się">
  <SignUpForm serverError={error} client:load />
  <p class="mt-4 text-center text-sm text-neutral-600">
    Masz już konto? <a href="/auth/signin" class="text-neutral-900 hover:underline">Zaloguj się</a>
  </p>
</AuthLayout>
