---

---

<div class="min-h-screen bg-neutral-50">
  <header class="border-b border-neutral-200 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
      <span class="text-base font-bold text-neutral-900">JobTracker</span>
      <div class="flex items-center gap-4">
        <a href="/auth/signin" class="text-sm text-neutral-600 transition-colors hover:text-neutral-900">
          Zaloguj się
        </a>
        <a
          href="/auth/signup"
          class="rounded-md border border-neutral-300 bg-white px-3 py-1.5 text-sm text-neutral-700 transition-colors hover:bg-neutral-100"
        >
          Zarejestruj się
        </a>
      </div>
    </nav>
  </header>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Hero section -->
    <div class="mx-auto flex max-w-3xl flex-col items-center px-4 py-20 text-center sm:py-28">
      <h1 class="mb-4 text-4xl font-bold text-neutral-900 sm:text-5xl">
        Śledź swoje aplikacje o pracę w jednym miejscu
      </h1>
      <p class="mb-8 max-w-xl text-lg text-neutral-600">
        JobTracker pomaga zbierać oferty pracy, porządkować je na tablicy Kanban i przechodzić przez kolejne etapy
        rekrutacji — od zainteresowania po ofertę.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href="/auth/signup"
          class="inline-flex items-center justify-center rounded-lg bg-neutral-900 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-neutral-800"
        >
          Zarejestruj się
        </a>
        <a
          href="/auth/signin"
          class="inline-flex items-center justify-center rounded-lg border border-neutral-300 bg-white px-6 py-3 text-base font-medium text-neutral-700 transition-colors hover:bg-neutral-100"
        >
          Zaloguj się
        </a>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid grid-cols-1 gap-6 pb-20 sm:grid-cols-3">
      <div class="rounded-xl border border-neutral-200 bg-white p-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mb-4 text-neutral-900"
        >
          <rect width="18" height="16" x="3" y="4" rx="2"></rect>
          <line x1="9" x2="9" y1="4" y2="20"></line>
          <line x1="15" x2="15" y1="4" y2="20"></line>
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-neutral-900">Tablica Kanban</h3>
        <p class="text-sm leading-relaxed text-neutral-600">
          Organizuj oferty na tablicy i przesuwaj je przez kolejne etapy rekrutacji (Interesujące → Zaaplikowano →
          Rozmowa).
        </p>
      </div>

      <div class="rounded-xl border border-neutral-200 bg-white p-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mb-4 text-neutral-900"
        >
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-neutral-900">Zapisuj i porządkuj oferty</h3>
        <p class="text-sm leading-relaxed text-neutral-600">
          Trzymaj wszystkie interesujące ogłoszenia w jednym miejscu.
        </p>
      </div>

      <div class="rounded-xl border border-neutral-200 bg-white p-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mb-4 text-neutral-900"
        >
          <path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5z"></path>
          <path d="M15 3v6h6"></path>
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-neutral-900">Notatki i przypomnienia</h3>
        <p class="text-sm leading-relaxed text-neutral-600">
          Dodawaj notatki i śledź follow-upy przy każdej aplikacji.
        </p>
      </div>
    </div>
  </div>
</div>
