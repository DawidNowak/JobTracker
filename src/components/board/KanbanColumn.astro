---
import { cn } from "@/lib/utils";
import KanbanCard from "@/components/board/KanbanCard.astro";
import type { ApplicationRow } from "@/types";

interface Props {
  title: string;
  applications: ApplicationRow[];
}

const { title, applications } = Astro.props;
const isEmpty = applications.length === 0;
const hasHeaderAction = Astro.slots.has("header-action");
---

<div class="flex min-h-[400px] flex-1 flex-col rounded-lg border border-neutral-200 bg-white">
  <header class={cn("flex items-center justify-between border-b border-neutral-200 px-4 py-3")}>
    <h2 class="text-sm font-semibold text-neutral-900">{title}</h2>
    {hasHeaderAction && <slot name="header-action" />}
  </header>
  {
    isEmpty ? (
      <div class="flex flex-1 items-center justify-center p-4">
        <p class="text-sm text-neutral-400">Brak aplikacji</p>
      </div>
    ) : (
      <div class="flex flex-col gap-2 p-3">
        {applications.map((application) => (
          <KanbanCard application={application} />
        ))}
      </div>
    )
  }
</div>
