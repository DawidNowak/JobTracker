---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="flex min-h-[400px] flex-1 flex-col rounded-lg border border-neutral-200 bg-white">
  <header class="border-b border-neutral-200 px-4 py-3">
    <h2 class="text-sm font-semibold text-neutral-900">{title}</h2>
  </header>
  <div class="flex flex-1 items-center justify-center p-4">
    <p class="text-sm text-neutral-400">Brak aplikacji</p>
  </div>
</div>
