---
import { formatDateTime } from "@/lib/format";
import type { ApplicationNoteRow } from "@/types";

interface Props {
  notes: ApplicationNoteRow[];
}

const { notes } = Astro.props;
---

<div class="flex flex-col gap-3">
  <h3 class="text-sm font-semibold text-neutral-900">Notatki</h3>

  {
    notes.length === 0 ? (
      <p class="text-sm text-neutral-500">Brak notatek.</p>
    ) : (
      <ul class="flex flex-col gap-2">
        {notes.map((note) => (
          <li class="rounded-md border border-neutral-200 bg-neutral-50 p-3">
            <p class="text-sm whitespace-pre-wrap text-neutral-800">{note.body}</p>
            <p class="mt-1 text-xs text-neutral-500">{formatDateTime(note.created_at)}</p>
          </li>
        ))}
      </ul>
    )
  }
</div>
