---
import Layout from "@/layouts/Layout.astro";
import { cn } from "@/lib/utils";

interface Props {
  title: string;
  heading?: string;
}

const { title, heading } = Astro.props;
---

<Layout title={title}>
  <header class="border-b border-neutral-200 bg-white">
    <nav class="mx-auto flex max-w-7xl items-center px-4 py-3 sm:px-6 lg:px-8">
      <a href="/" class="text-base font-bold text-neutral-900">JobTracker</a>
    </nav>
  </header>

  <div class={cn("flex min-h-screen items-center justify-center bg-neutral-50 p-4")}>
    <div class={cn("w-full max-w-sm rounded-xl border border-neutral-200 bg-white p-8 shadow-sm")}>
      {heading && <h1 class="mb-6 text-center text-2xl font-bold text-neutral-900">{heading}</h1>}
      <slot />
    </div>
  </div>
</Layout>
